---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const lessons = await getCollection('cicd');
  const sorted = lessons.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((entry, index) => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: {
      entry,
      prev: sorted[index - 1] ?? null,
      next: sorted[index + 1] ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

const allLessons = await getCollection('cicd');
const sorted = allLessons.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout 
  title={entry.data.title}
  description={entry.data.description}
  keywords={entry.data.tags || ['CI/CD', 'DevOps']}
  ogType="article"
  certifications={entry.data.certifications}
>
  <div class="flex min-h-screen">

    <!-- Sidebar -->
    <aside class="hidden lg:flex flex-col w-64 shrink-0 border-r border-white/10 pt-8 pb-24 sticky top-0 h-screen overflow-y-auto">
      <div class="px-4 mb-6">
        <a href="/cicd" class="text-xs text-gray-500 hover:text-gray-300 transition-colors">
          ← CI/CD
        </a>
      </div>
      {sorted.map((lesson, index) => {
        const lessonSlug = lesson.id.replace(/\.md$/, '');
        const isActive = lessonSlug === Astro.params.slug;
        return (
          <a
            href={`/cicd/${lessonSlug}`}
            class={`flex items-center gap-3 px-4 py-2.5 text-sm transition-colors ${
              isActive
                ? 'text-green-400 bg-green-500/10 border-r-2 border-green-500'
                : 'text-gray-500 hover:text-gray-300 hover:bg-white/5'
            }`}
          >
            <span class="tabular-nums text-xs w-5 shrink-0 opacity-50">
              {String(index + 1).padStart(2, '0')}
            </span>
            {lesson.data.title}
          </a>
        );
      })}
    </aside>

    <!-- Main content -->
    <main class="flex-1 min-w-0 px-8 lg:px-16 py-12 max-w-3xl">

      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 text-xs text-gray-600 mb-8">
        <a href="/cicd" class="hover:text-gray-400 transition-colors">CI/CD</a>
        <span>/</span>
        <span class="text-gray-400">{entry.data.title}</span>
      </div>

      <!-- Lesson header -->
      <div class="mb-10">
        <h1 class="text-4xl font-black tracking-tight mb-3">{entry.data.title}</h1>
        <p class="text-gray-400">{entry.data.description}</p>
        <div class="flex items-center gap-4 mt-4">
          {entry.data.duration && (
            <span class="text-xs text-gray-600">{entry.data.duration} min read</span>
          )}
          {entry.data.tags && entry.data.tags.map(tag => (
            <span class="text-xs px-2 py-0.5 rounded-full bg-green-500/10 text-green-400 border border-green-500/20">
              {tag}
            </span>
          ))}
        </div>
      </div>

      <!-- Markdown content -->
      <article class="prose prose-invert prose-green max-w-none">
        <Content />
      </article>

      <!-- Prev / Next -->
      <div class="flex items-center justify-between mt-16 pt-8 border-t border-white/10">
        {prev ? (
          <a
            href={`/cicd/${prev.id.replace(/\.md$/, '')}`}
            class="flex flex-col gap-1 group"
          >
            <span class="text-xs text-gray-600 group-hover:text-gray-400 transition-colors">← Previous</span>
            <span class="text-sm font-medium group-hover:text-green-400 transition-colors">{prev.data.title}</span>
          </a>
        ) : <div />}

        {next ? (
          <a
            href={`/cicd/${next.id.replace(/\.md$/, '')}`}
            class="flex flex-col gap-1 items-end group"
          >
            <span class="text-xs text-gray-600 group-hover:text-gray-400 transition-colors">Next →</span>
            <span class="text-sm font-medium group-hover:text-green-400 transition-colors">{next.data.title}</span>
          </a>
        ) : <div />}
      </div>

    </main>
  </div>
</BaseLayout>