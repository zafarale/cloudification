---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('networking', ({ id }) => id.startsWith('protocols/'));

// Group by first segment after 'protocols/'
const grouped: Record<string, typeof all> = {};
for (const lesson of all) {
  const parts = lesson.id.replace('protocols/', '').split('/');
  if (parts.length < 2) continue;
  const group = parts[0];
  if (!grouped[group]) grouped[group] = [];
  grouped[group].push(lesson);
}

const totalLessons = all.length;
const totalDuration = all.reduce((acc, l) => acc + (l.data.duration ?? 0), 0);
---

<BaseLayout
  title="Network Protocols"
  description="Learn network protocols that power the internet. HTTP, TCP/IP, DNS, WebSockets, gRPC, and application-layer communication."
  keywords={['network protocols', 'HTTP', 'TCP/IP', 'DNS', 'WebSockets', 'gRPC', 'application layer']}
>
  <PageHeader
    title="Protocols"
    description="HTTP, TCP/IP, DNS, WebSockets, gRPC, and the protocols that power modern networked systems."
    icon="🔌"
    backHref="/networking"
    backLabel="Back to Networking"
    lessonCount={totalLessons}
    totalDuration={totalDuration}
  />
  <section class="max-w-6xl mx-auto px-6 pb-16 flex flex-wrap justify-center gap-6">
    {Object.entries(grouped).map(([groupSlug, lessons]) => {
      const sorted = [...lessons].sort((a, b) => a.data.order - b.data.order);
      const label = groupSlug.replace(/-/g, ' ');
      return (
        <FeatureCard
          title={label}
          description={sorted.map(l => l.data.title).join(', ')}
          href={`/networking/protocols/${groupSlug}`}
          color="green"
          icon="mdi:network-outline"
          lessonCount={sorted.length}
          ctaText={`Explore ${label}`}
        />
      );
    })}
  </section>
</BaseLayout>

