---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LessonSidebar from '../../../components/LessonSidebar.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import PrevNext from '../../../components/PrevNext.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('data');
  const lessons = all.filter(({ id }) => id.startsWith('sql/'));
  const sorted = lessons.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((entry, index) => ({
    params: {
      slug: entry.id
        .replace('sql/', '')
        .replace(/\.mdx$/, '')
        .replace(/\.md$/, ''),
    },
    props: {
      entry,
      prev: sorted[index - 1] ?? null,
      next: sorted[index + 1] ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

const allLessons = await getCollection('data', ({ id }) => id.startsWith('sql/'));
const sorted = allLessons.sort((a, b) => a.data.order - b.data.order);

const sidebarLessons = sorted.map(lesson => ({
  title: lesson.data.title,
  href: `/data/sql/${lesson.id.replace('sql/', '').replace(/\.md$/, '').replace(/\.mdx$/, '')}`,
  order: lesson.data.order,
  icon: lesson.data.icon,
}));

const prevLesson = prev
  ? { title: prev.data.title, href: `/data/sql/${prev.id.replace('sql/', '').replace(/\.md$/, '').replace(/\.mdx$/, '')}` }
  : null;

const nextLesson = next
  ? { title: next.data.title, href: `/data/sql/${next.id.replace('sql/', '').replace(/\.md$/, '').replace(/\.mdx$/, '')}` }
  : null;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  keywords={entry.data.tags || ['SQL', 'data', 'databases']}
  ogType="article"
  certifications={entry.data.certifications}
>
  <div class="flex min-h-screen">
    <LessonSidebar
      lessons={sidebarLessons}
      currentSlug={Astro.params.slug}
      backHref="/data/sql"
      backLabel="SQL"
      color="cyan"
    />
    <main class="flex-1 min-w-0 px-8 lg:px-16 py-12 max-w-3xl">
      <Breadcrumb crumbs={[
        { label: 'Data', href: '/data' },
        { label: 'SQL', href: '/data/sql' },
        { label: entry.data.title },
      ]} />
      <div class="mb-10">
        <h1 class="text-4xl font-black tracking-tight font-mono mb-3">{entry.data.title}</h1>
        <p class="text-gray-400">{entry.data.description}</p>
        <div class="flex items-center gap-4 mt-4">
          {entry.data.duration && (
            <span class="text-xs text-gray-600">{entry.data.duration} min read</span>
          )}
          {entry.data.tags && entry.data.tags.map(tag => (
            <span class="text-xs px-2 py-0.5 rounded-full bg-cyan-500/10 text-cyan-400 border border-cyan-500/20">
              {tag}
            </span>
          ))}
        </div>
      </div>
      <article class="prose prose-invert prose-cyan max-w-none">
        <Content />
      </article>
      <PrevNext prev={prevLesson} next={nextLesson} color="cyan" />
    </main>
  </div>
</BaseLayout>