---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import LessonList from '../../../components/LessonList.astro';
import { getCollection } from 'astro:content';

const lessons = await getCollection('data', ({ id }) => id.startsWith('sql/'));
const sorted = lessons.sort((a, b) => a.data.order - b.data.order);
const totalDuration = sorted.reduce((acc, l) => acc + (l.data.duration ?? 0), 0);

const lessonItems = sorted.map(lesson => ({
  title: lesson.data.title,
  description: lesson.data.description,
  href: `/data/sql/${lesson.id.replace('sql/', '').replace(/\.mdx?$/, '')}`,
  order: lesson.data.order,
  duration: lesson.data.duration,
  tags: lesson.data.tags,
  icon: lesson.data.icon,
}));
---

<BaseLayout
  title="SQL"
  description="Relational databases, queries, joins, indexes, and transactions. The foundation every developer needs."
  keywords={['SQL tutorials', 'PostgreSQL', 'MySQL', 'relational database', 'database design', 'joins', 'indexes']}
  certifications={['AWS Database Specialty', 'Google Cloud Professional Data Engineer', 'PostgreSQL Certified']}
>
  <PageHeader
    title="SQL"
    description="Relational databases from the ground up. Work through lessons in order — each builds on the last."
    icon="🗃️"
    backHref="/data"
    backLabel="Back to Data"
    lessonCount={sorted.length}
    totalDuration={totalDuration}
  />
  <LessonList lessons={lessonItems} color="cyan" />
</BaseLayout>
