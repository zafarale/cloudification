---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import LessonList from '../../../components/LessonList.astro';
import { getCollection } from 'astro:content';

const lessons = await getCollection('data', ({ id }) => id.startsWith('common/'));
const sorted = lessons.sort((a, b) => a.data.order - b.data.order);
const totalDuration = sorted.reduce((acc, l) => acc + (l.data.duration ?? 0), 0);

const lessonItems = sorted.map(lesson => ({
  title: lesson.data.title,
  description: lesson.data.description,
  href: `/data/common/${lesson.id.replace('common/', '').replace(/\.mdx?$/, '')}`,
  order: lesson.data.order,
  duration: lesson.data.duration,
  tags: lesson.data.tags,
  icon: lesson.data.icon,
}));
---

<BaseLayout
  title="Shared Data Concepts"
  description="Core data concepts shared across all tracks. Foundations that underpin SQL, NoSQL, and data warehousing."
  keywords={['data concepts', 'shared concepts', 'data fundamentals', 'database theory']}
>
  <PageHeader
    title="Shared Concepts"
    description="Core data concepts that apply across all tracks — SQL, NoSQL, and warehousing alike."
    icon="🔗"
    backHref="/data"
    backLabel="Back to Data"
    lessonCount={sorted.length}
    totalDuration={totalDuration}
  />
  <LessonList lessons={lessonItems} color="purple" />
</BaseLayout>
