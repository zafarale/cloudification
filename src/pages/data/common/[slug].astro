---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LessonSidebar from '../../../components/LessonSidebar.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import PrevNext from '../../../components/PrevNext.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('data');
  const lessons = all.filter(({ id }) => id.startsWith('common/'));
  const sorted = lessons.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((entry, index) => ({
    params: {
      slug: entry.id
        .replace('common/', '')
        .replace(/\.mdx?$/, ''),
    },
    props: {
      entry,
      prev: sorted[index - 1] ?? null,
      next: sorted[index + 1] ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

const allLessons = await getCollection('data', ({ id }) => id.startsWith('common/'));
const sorted = allLessons.sort((a, b) => a.data.order - b.data.order);

const sidebarLessons = sorted.map(lesson => ({
  title: lesson.data.title,
  href: `/data/common/${lesson.id.replace('common/', '').replace(/\.mdx?$/, '')}`,
  order: lesson.data.order,
  icon: lesson.data.icon,
}));

const prevLesson = prev
  ? { title: prev.data.title, href: `/data/common/${prev.id.replace('common/', '').replace(/\.mdx?$/, '')}` }
  : null;

const nextLesson = next
  ? { title: next.data.title, href: `/data/common/${next.id.replace('common/', '').replace(/\.mdx?$/, '')}` }
  : null;

const trackMeta: Record<string, { label: string; emoji: string; classes: string; href: string }> = {
  sql:        { label: 'SQL',        emoji: '🗃️', href: '/data/sql',        classes: 'bg-cyan-500/10 text-cyan-400 border-cyan-500/20 hover:bg-cyan-500/20' },
  nosql:      { label: 'NoSQL',      emoji: '🍃', href: '/data/nosql',      classes: 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20 hover:bg-yellow-500/20' },
  warehousing:{ label: 'Warehousing',emoji: '🏭', href: '/data/warehousing',classes: 'bg-purple-500/10 text-purple-400 border-purple-500/20 hover:bg-purple-500/20' },
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  keywords={entry.data.tags || ['data', 'shared concepts']}
  ogType="article"
  certifications={entry.data.certifications}
>
  <div class="flex min-h-screen">
    <LessonSidebar
      lessons={sidebarLessons}
      currentSlug={Astro.params.slug}
      backHref="/data"
      backLabel="Data"
      color="purple"
    />
    <main class="flex-1 min-w-0 px-8 lg:px-16 py-12 max-w-3xl">

      <Breadcrumb crumbs={[
        { label: 'Data', href: '/data' },
        { label: 'Shared Concepts', href: '/data' },
        { label: entry.data.title },
      ]} />

      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-purple-500/10 border border-purple-500/20 mb-8">
        <span class="text-xs font-semibold text-purple-400 uppercase tracking-widest">
          🔗 Shared Concept
        </span>
      </div>

      <div class="mb-10">
        <h1 class="text-4xl font-black tracking-tight font-mono mb-3">{entry.data.title}</h1>
        <p class="text-gray-400">{entry.data.description}</p>
        <div class="flex items-center gap-4 mt-4">
          {entry.data.duration && (
            <span class="text-xs text-gray-600">{entry.data.duration} min read</span>
          )}
          {entry.data.tags && entry.data.tags.map(tag => (
            <span class="text-xs px-2 py-0.5 rounded-full bg-purple-500/10 text-purple-400 border border-purple-500/20">
              {tag}
            </span>
          ))}
        </div>
      </div>

      {entry.data.sharedWith && entry.data.sharedWith.length > 0 && (
        <div class="mb-8 rounded-lg border border-white/10 bg-white/5 p-4">
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-3">
            Applies to
          </p>
          <div class="flex flex-wrap gap-3">
            {entry.data.sharedWith.map(track => {
              const meta = trackMeta[track];
              if (!meta) return null;
              return (
                <a
                  href={meta.href}
                  class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold border transition-colors ${meta.classes}`}
                >
                  <span>{meta.emoji}</span>
                  {meta.label}
                </a>
              );
            })}
          </div>
        </div>
      )}

      <article class="prose prose-invert prose-purple max-w-none">
        <Content />
      </article>

      <PrevNext prev={prevLesson} next={nextLesson} color="purple" />
    </main>
  </div>
</BaseLayout>