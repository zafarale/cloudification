---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import LessonList from '../../../components/LessonList.astro';
import { getCollection } from 'astro:content';

const lessons = await getCollection('data', ({ id }) => id.startsWith('warehousing/'));
const sorted = lessons.sort((a, b) => a.data.order - b.data.order);
const totalDuration = sorted.reduce((acc, l) => acc + (l.data.duration ?? 0), 0);

const lessonItems = sorted.map(lesson => ({
  title: lesson.data.title,
  description: lesson.data.description,
  href: `/data/warehousing/${lesson.id.replace('warehousing/', '').replace(/\.mdx?$/, '')}`,
  order: lesson.data.order,
  duration: lesson.data.duration,
  tags: lesson.data.tags,
  icon: lesson.data.icon,
}));
---

<BaseLayout
  title="Data Warehousing"
  description="Data warehouses, lakes, ETL pipelines, and analytical query engines at scale."
  keywords={['data warehousing', 'Snowflake', 'AWS Redshift', 'BigQuery', 'ETL pipelines', 'data lake', 'analytical queries']}
  certifications={['Snowflake SnowPro Core', 'AWS Database Specialty', 'Google Cloud Professional Data Engineer']}
>
  <PageHeader
    title="Warehousing"
    description="Data warehouses, lakes, ETL pipelines, and analytical engines at scale. Work through lessons in order."
    icon="🏭"
    backHref="/data"
    backLabel="Back to Data"
    lessonCount={sorted.length}
    totalDuration={totalDuration}
  />
  <LessonList lessons={lessonItems} color="purple" />
</BaseLayout>
