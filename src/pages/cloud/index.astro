---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TutorialHeader from '../../components/TutorialHeader.astro';
import SharedLessons from '../../components/SharedLessons.astro';
import CrossPathNote from '../../components/CrossPathNote.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import { getCollection } from 'astro:content';

const awsLessons = await getCollection('cloud', ({ id }) =>
  id.startsWith('aws/')
);
const azureLessons = await getCollection('cloud', ({ id }) =>
  id.startsWith('azure/')
);
const commonLessons = await getCollection('cloud', ({ id }) =>
  id.startsWith('common/') || id.startsWith('_common/')
);
---

<BaseLayout 
  title="Cloud"
  description="Learn cloud computing on AWS and Azure. From EC2 and S3 to serverless functions and Kubernetes — build and scale cloud infrastructure."
  keywords={['AWS tutorials', 'Azure tutorials', 'cloud computing', 'EC2', 'S3', 'Lambda', 'Azure Functions', 'Kubernetes', 'cloud infrastructure']}
  certifications={['AWS Solutions Architect', 'AWS Developer Associate', 'Azure Administrator', 'Azure Developer Associate', 'AWS Cloud Practitioner']}
>

  <TutorialHeader
    title="Cloud"
    description="Choose a cloud provider. Both share core infrastructure concepts — you'll see them highlighted as you progress."
    emoji="☁️"
    lessonCount={awsLessons.length + azureLessons.length}
    sharedCount={commonLessons.length}
  />

  <!-- Track cards -->
  <section class="max-w-5xl mx-auto px-6 pb-16 flex flex-wrap justify-center gap-6">
    <FeatureCard
      title="Amazon Web Services"
      description="The world's largest cloud platform. From EC2 and S3 to Lambda and beyond — learn to build and scale on AWS."
      href="/cloud/aws"
      iconDay="skill-icons:aws-dark"
      iconNight="skill-icons:aws-light"
      color="orange"
      lessonCount={awsLessons.length}
    />

    <FeatureCard
      title="Microsoft Azure"
      description="Enterprise-grade cloud with deep Microsoft integration. VMs, Azure Functions, AKS and the full Azure ecosystem."
      href="/cloud/azure"
      iconDay="skill-icons:azure-dark"
      iconNight="skill-icons:azure-light"
      color="blue"
      lessonCount={azureLessons.length}
    />
  </section>

  <SharedLessons
    lessons={commonLessons}
    basePath="/cloud/common"
    title="Shared across both providers"
    color="cyan"
  />

  <CrossPathNote
    title="Cloud connects to every other path"
    description="Your code runs on cloud infrastructure. CI/CD pipelines deploy to cloud services. Databases are hosted in the cloud. Networking underpins all cloud architecture. Look out for cross-path callouts as you progress."
  />

</BaseLayout>