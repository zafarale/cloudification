---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import LessonList from '../../../components/LessonList.astro';
import { getCollection } from 'astro:content';
import { toTrackSlug, lessonListIconMap } from '../../../lib/content-slugs';

const lessons = await getCollection('cloud', ({ id }) => id.startsWith('aws/'));
const sorted = lessons.sort((a, b) => a.data.order - b.data.order);
const totalDuration = sorted.reduce((acc, l) => acc + (l.data.duration ?? 0), 0);

const lessonItems = sorted.map(lesson => {
  const slug = toTrackSlug(lesson.id, 'aws');
  return {
    title: lesson.data.title,
    description: lesson.data.description,
    href: `/cloud/aws/${slug}`,
    order: lesson.data.order,
    duration: lesson.data.duration,
    tags: lesson.data.tags,
    icon: lessonListIconMap[slug] ?? lesson.data.icon,
  };
});
---

<BaseLayout
  title="AWS"
  description="Learn Amazon Web Services from the ground up. EC2, S3, Lambda, RDS, and building scalable cloud infrastructure on AWS."
  keywords={['AWS tutorials', 'Amazon Web Services', 'EC2', 'S3', 'Lambda', 'RDS', 'cloud infrastructure', 'serverless']}
  certifications={['AWS Solutions Architect Associate', 'AWS Developer Associate', 'AWS Cloud Practitioner', 'AWS SysOps Administrator']}
>
  <PageHeader
    title="Amazon Web Services"
    description="Amazon Web Services from the ground up. Work through lessons in order — each builds on the last."
    iconName="logos:aws"
    backHref="/cloud"
    backLabel="Back to Cloud"
    lessonCount={sorted.length}
    totalDuration={totalDuration}
  />
  <LessonList lessons={lessonItems} color="amber" />
</BaseLayout>