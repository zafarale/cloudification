---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LessonSidebar from '../../../components/LessonSidebar.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import LessonList from '../../../components/LessonList.astro';
import PrevNext from '../../../components/PrevNext.astro';
import { Icon } from 'astro-icon/components';
import { getCollection, render } from 'astro:content';
import { toCommonIdCandidates, toCommonSlug } from '../../../lib/content-slugs';
import { buildSubTrackPaths, type SubTrackPageProps } from '../../../lib/lesson-layout';

export async function getStaticPaths() {
  const all = await getCollection('cloud');
  const entries = all.filter(({ id }) => id.startsWith('gcp/'));
  return buildSubTrackPaths(entries, 'gcp/', '/cloud/gcp');
}

const page = Astro.props as SubTrackPageProps;

let Content: any = null;
let sharedConcepts: any[] = [];

if (page.type === 'lesson') {
  ({ Content } = await render(page.entry));
  sharedConcepts = page.entry.data.sharedConcepts
    ? await getCollection('cloud', ({ id }) =>
        page.entry.data.sharedConcepts!.some((sc: string) => toCommonIdCandidates(sc).includes(id))
      )
    : [];
}

const sidebarGroups = page.sidebarData.mode === 'grouped' ? page.sidebarData.groups : undefined;
const sidebarLessons = page.sidebarData.mode === 'flat' ? page.sidebarData.lessons : undefined;
const currentSlug = Astro.params.slug as string;
---

<BaseLayout
  title={page.type === 'lesson' ? page.entry.data.title : `${page.groupLabel} — GCP`}
  description={page.type === 'lesson' ? page.entry.data.description : `GCP: ${page.groupLabel}.`}
  keywords={page.type === 'lesson' ? (page.entry.data.tags || ['GCP', 'Google Cloud', 'cloud']) : ['GCP', 'Google Cloud', 'cloud']}
  ogType={page.type === 'lesson' ? 'article' : undefined}
  certifications={page.type === 'lesson' ? page.entry.data.certifications : undefined}
>
  <LessonSidebar
      groups={sidebarGroups}
      lessons={sidebarLessons}
      currentSlug={currentSlug}
      backHref="/cloud/gcp"
      backLabel="GCP"
      color="green"
  >
    <main class="flex-1 min-w-0 px-8 lg:px-16 py-12 max-w-3xl">

      {page.type === 'group-index' && (
        <>
          <Breadcrumb crumbs={[
            { label: 'Cloud', href: '/cloud' },
            { label: 'GCP', href: '/cloud/gcp' },
            { label: page.groupLabel },
          ]} />
          <div class="mb-10">
            <h1 class="text-4xl font-black tracking-tight font-mono mb-2 capitalize">{page.groupLabel}</h1>
            <p class="text-gray-400 text-sm mt-2">
              {page.groupLessons.length} {page.groupLessons.length === 1 ? 'lesson' : 'lessons'}
              {page.totalDuration > 0 && ` · ${page.totalDuration} min`}
            </p>
          </div>
          <LessonList lessons={page.groupLessons} color="green" />
        </>
      )}

      {page.type === 'lesson' && Content && (
        <>
          <Breadcrumb crumbs={[
            { label: 'Cloud', href: '/cloud' },
            { label: 'GCP', href: '/cloud/gcp' },
            ...(page.breadcrumbExtra ? [page.breadcrumbExtra] : []),
            { label: page.entry.data.title },
          ]} />
          <div class="mb-10">
            <div class="flex items-center gap-4 mb-4">
              {page.entry.data.icon && <Icon name={page.entry.data.icon} class="w-10 h-10" />}
              <h1 class="text-4xl font-black tracking-tight font-mono">{page.entry.data.title}</h1>
            </div>
            <p class="text-gray-400">{page.entry.data.description}</p>
            <div class="flex items-center gap-4 mt-4">
              {page.entry.data.duration && (
                <span class="text-xs text-gray-600">{page.entry.data.duration} min read</span>
              )}
              {page.entry.data.tags && page.entry.data.tags.map((tag: string) => (
                <span class="text-xs px-2 py-0.5 rounded-full bg-green-500/10 text-green-400 border border-green-500/20">{tag}</span>
              ))}
            </div>
          </div>
          {sharedConcepts.length > 0 && (
            <div class="mb-8 rounded-lg border border-yellow-500/20 bg-yellow-500/5 p-4">
              <p class="text-xs font-semibold uppercase tracking-widest text-yellow-500 mb-2">🔗 Shared Concept</p>
              <p class="text-sm text-gray-400">
                This lesson builds on{' '}
                {sharedConcepts.map((sc: any) => (
                  <a href={`/cloud/common/${toCommonSlug(sc.id)}`} class="text-yellow-400 underline underline-offset-2 hover:text-yellow-300">
                    {sc.data.title}
                  </a>
                ))}{' '}
                — a concept also relevant to AWS and Azure.
              </p>
            </div>
          )}
          <article class="prose prose-invert prose-green max-w-none">
            <Content />
          </article>
          <PrevNext prev={page.prevLesson} next={page.nextLesson} color="green" />
        </>
      )}

    </main>
  </LessonSidebar>
</BaseLayout>
