---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import { toTrackSlug } from '../../../lib/content-slugs';
const lessons = await getCollection('cloud', ({ id }) =>
  id.startsWith('azure/')
);

const sorted = lessons.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout 
  title="Azure"
  description="Learn Microsoft Azure from the ground up. Virtual machines, Azure Functions, AKS, and enterprise cloud infrastructure."
  keywords={['Azure tutorials', 'Microsoft Azure', 'Azure Functions', 'AKS', 'Kubernetes', 'cloud infrastructure', 'enterprise cloud']}
  certifications={['Azure Administrator AZ-104', 'Azure Developer AZ-204', 'Azure Fundamentals AZ-900', 'Azure Solutions Architect AZ-305']}
>

  <section class="max-w-4xl mx-auto px-6 pt-16 pb-12">
    <a href="/cloud" class="text-sm text-gray-500 hover:text-gray-300 transition-colors mb-6 inline-block">
      ← Back to Cloud
    </a>
    <div class="flex items-center gap-4 mb-4">
      <Icon name="logos:azure" class="text-5xl" />
      <h1 class="text-5xl font-black tracking-tight">Microsoft Azure</h1>
    </div>
    <p class="text-gray-400 text-lg max-w-2xl">
      Microsoft Azure from the ground up. Work through lessons in order — each builds on the last.
    </p>
    <div class="flex gap-6 mt-8 text-sm text-gray-500">
      <span>{sorted.length} lessons</span>
      {sorted.reduce((acc, l) => acc + (l.data.duration ?? 0), 0) > 0 && (
        <span>{sorted.reduce((acc, l) => acc + (l.data.duration ?? 0), 0)} min total</span>
      )}
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 pb-24">
    <div class="rounded-xl border border-white/10 bg-white/5 divide-y divide-white/5">
      {sorted.map((lesson, index) => {
        const slug = toTrackSlug(lesson.id, 'azure');
        return (
          <a
            href={`/cloud/azure/${slug}`}
            class="flex items-center gap-6 px-6 py-5 hover:bg-white/5 transition-colors group"
          >
            <span class="text-2xl font-black text-blue-500/30 group-hover:text-blue-500/60 transition-colors w-8 shrink-0 tabular-nums">
              {String(index + 1).padStart(2, '0')}
            </span>
            <div class="flex-1 min-w-0">
              <p class="font-semibold group-hover:text-blue-100 transition-colors">
                {lesson.data.title}
              </p>
              <p class="text-sm text-gray-500 mt-0.5 truncate">
                {lesson.data.description}
              </p>
              {lesson.data.tags && lesson.data.tags.length > 0 && (
                <div class="flex gap-2 mt-2">
                  {lesson.data.tags.map(tag => (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-blue-500/10 text-blue-400 border border-blue-500/20">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
            <div class="flex items-center gap-4 shrink-0">
              {lesson.data.duration && (
                <span class="text-xs text-gray-600">{lesson.data.duration}m</span>
              )}
              <span class="text-gray-600 group-hover:text-blue-400 group-hover:translate-x-1 transition-all duration-200">
                →
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </section>

</BaseLayout>