---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import LessonList from '../../../components/LessonList.astro';
import { getCollection } from 'astro:content';
import { toTrackSlug } from '../../../lib/content-slugs';

const lessons = await getCollection('cloud', ({ id }) => id.startsWith('azure/'));
const sorted = lessons.sort((a, b) => a.data.order - b.data.order);
const totalDuration = sorted.reduce((acc, l) => acc + (l.data.duration ?? 0), 0);

const lessonItems = sorted.map(lesson => ({
  title: lesson.data.title,
  description: lesson.data.description,
  href: `/cloud/azure/${toTrackSlug(lesson.id, 'azure')}`,
  order: lesson.data.order,
  duration: lesson.data.duration,
  tags: lesson.data.tags,
  icon: lesson.data.icon,
}));
---

<BaseLayout
  title="Azure"
  description="Learn Microsoft Azure from the ground up. Virtual machines, Azure Functions, AKS, and enterprise cloud infrastructure."
  keywords={['Azure tutorials', 'Microsoft Azure', 'Azure Functions', 'AKS', 'Kubernetes', 'cloud infrastructure', 'enterprise cloud']}
  certifications={['Azure Administrator AZ-104', 'Azure Developer AZ-204', 'Azure Fundamentals AZ-900', 'Azure Solutions Architect AZ-305']}
>
  <PageHeader
    title="Microsoft Azure"
    description="Microsoft Azure from the ground up. Work through lessons in order — each builds on the last."
    iconName="logos:azure"
    backHref="/cloud"
    backLabel="Back to Cloud"
    lessonCount={sorted.length}
    totalDuration={totalDuration}
  />
  <LessonList lessons={lessonItems} color="blue" />
</BaseLayout>

</BaseLayout>