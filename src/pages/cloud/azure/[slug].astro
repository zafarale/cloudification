---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { Icon } from 'astro-icon/components';
import { toCommonIdCandidates, toCommonSlug, toTrackSlug } from '../../../lib/content-slugs';
export async function getStaticPaths() {
  const lessons = await getCollection('cloud', ({ id }) =>
    id.startsWith('azure/')
  );

  const sorted = lessons.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((entry, index) => ({
    params: { slug: toTrackSlug(entry.id, 'azure') },
    props: {
      entry,
      prev: sorted[index - 1] ?? null,
      next: sorted[index + 1] ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

const allLessons = await getCollection('cloud', ({ id }) =>
  id.startsWith('azure/')
);
const sorted = allLessons.sort((a, b) => a.data.order - b.data.order);

const sharedConcepts = entry.data.sharedConcepts
  ? await getCollection('cloud', ({ id }) =>
      entry.data.sharedConcepts!.some(sc => toCommonIdCandidates(sc).includes(id))
    )
  : [];
---

<BaseLayout 
  title={entry.data.title}
  description={entry.data.description}
  keywords={entry.data.tags || ['Azure', 'cloud']}
  ogType="article"
  certifications={entry.data.certifications}
>
  <div class="flex min-h-screen">

    <!-- Sidebar -->
    <aside class="hidden lg:flex flex-col w-64 shrink-0 border-r border-white/10 pt-8 pb-24 sticky top-0 h-screen overflow-y-auto">
      <div class="px-4 mb-6">
        <a href="/cloud/azure" class="text-xs text-gray-500 hover:text-gray-300 transition-colors">
          ← Azure
        </a>
      </div>
      {sorted.map((lesson, index) => {
        const lessonSlug = toTrackSlug(lesson.id, 'azure');
        const isActive = lessonSlug === Astro.params.slug;
        return (
          <a
            href={`/cloud/azure/${lessonSlug}`}
            class={`flex items-center gap-3 px-4 py-2.5 text-sm transition-colors ${
              isActive
                ? 'text-yellow-400 bg-yellow-500/10 border-r-2 border-yellow-500'
                : 'text-gray-500 hover:text-gray-300 hover:bg-white/5'
            }`}
          >
            <span class="tabular-nums text-xs w-5 shrink-0 opacity-50">
              {String(index + 1).padStart(2, '0')}
            </span>
            {lesson.data.title}
          </a>
        );
      })}
    </aside>

    <!-- Main content -->
    <main class="flex-1 min-w-0 px-8 lg:px-16 py-12 max-w-3xl">

      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 text-xs text-gray-600 mb-8">
        <a href="/cloud" class="hover:text-gray-400 transition-colors">Cloud</a>
        <span>/</span>
        <a href="/cloud/azure" class="hover:text-gray-400 transition-colors">Azure</a>
        <span>/</span>
        <span class="text-gray-400">{entry.data.title}</span>
      </div>

      <!-- Lesson header -->
      <div class="mb-10">

        <!-- Add icon here -->
        <div class="flex items-center gap-4 mb-4">
          {entry.data.icon && (
            <Icon name={entry.data.icon} class="w-10 h-10" />
          )}
          <h1 class="text-4xl font-black tracking-tight font-mono">
            {entry.data.title}
          </h1>
        </div>

        <p class="text-gray-400">{entry.data.description}</p>
        <div class="flex items-center gap-4 mt-4">
          {entry.data.duration && (
            <span class="text-xs text-gray-600">{entry.data.duration} min read</span>
          )}
          {entry.data.tags && entry.data.tags.map(tag => (
            <span class="text-xs px-2 py-0.5 rounded-full bg-orange-500/10 text-orange-400 border border-orange-500/20">
              {tag}
            </span>
          ))}
        </div>
      </div>

      <!-- Shared concept callout -->
      {sharedConcepts.length > 0 && (
        <div class="mb-8 rounded-lg border border-yellow-500/20 bg-yellow-500/5 p-4">
          <p class="text-xs font-semibold uppercase tracking-widest text-yellow-500 mb-2">
            🔗 Shared Concept
          </p>
          <p class="text-sm text-gray-400">
            This lesson builds on{' '}
            {sharedConcepts.map(sc => (
              <a
                href={`/cloud/common/${toCommonSlug(sc.id)}`}
                class="text-yellow-400 underline underline-offset-2 hover:text-yellow-300"
              >
                {sc.data.title}
              </a>
            ))}{' '}
            — a concept also relevant to Azure.
          </p>
        </div>
      )}

      <!-- Markdown content -->
      <article data-track class="prose prose-invert prose-blue max-w-none" style="--track: var(--color-blue-400); --track-bg: color-mix(in srgb, var(--color-blue-500) 10%, transparent); --track-border: color-mix(in srgb, var(--color-blue-500) 20%, transparent)">
        <Content />
      </article>

      <!-- Prev / Next -->
      <div class="flex items-center justify-between mt-16 pt-8 border-t border-white/10">
        {prev ? (
          <a
            href={`/cloud/azure/${toTrackSlug(prev.id, 'azure')}`}
            class="flex flex-col gap-1 group"
          >
            <span class="text-xs text-gray-600 group-hover:text-gray-400 transition-colors">← Previous</span>
            <span class="text-sm font-medium group-hover:text-yellow-400 transition-colors">{prev.data.title}</span>
          </a>
        ) : <div />}

        {next ? (
          <a
            href={`/cloud/azure/${toTrackSlug(next.id, 'azure')}`}
            class="flex flex-col gap-1 items-end group"
          >
            <span class="text-xs text-gray-600 group-hover:text-gray-400 transition-colors">Next →</span>
            <span class="text-sm font-medium group-hover:text-yellow-400 transition-colors">{next.data.title}</span>
          </a>
        ) : <div />}
      </div>

    </main>
  </div>
</BaseLayout>