---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import LessonList from '../../../components/LessonList.astro';
import { getCollection } from 'astro:content';

const lessons = await getCollection('programming', ({ id }) =>
  id.startsWith('rust/')
);
const sorted = lessons.sort((a, b) => a.data.order - b.data.order);
const totalDuration = sorted.reduce((acc, l) => acc + (l.data.duration ?? 0), 0);

const lessonItems = sorted.map(lesson => ({
  title: lesson.data.title,
  description: lesson.data.description,
  href: `/programming/rust/${lesson.id.replace('rust/', '').replace(/\.mdx?$/, '')}`,
  order: lesson.data.order,
  duration: lesson.data.duration,
  tags: lesson.data.tags,
}));
---

<BaseLayout 
  title="Rust"
  description="Learn Rust for systems programming with memory safety. Ownership, borrowing, concurrency, and building safe, fast applications."
  keywords={['Rust programming', 'systems programming', 'memory safety', 'ownership', 'borrowing', 'concurrency', 'Rust tutorials']}
>
  <PageHeader
    title="Rust"
    description="From systems programming to safe and concurrent applications. Work through lessons in order — each builds on the last."
    icon="🦀"
    backHref="/programming"
    backLabel="Back to Programming"
    lessonCount={sorted.length}
    totalDuration={totalDuration}
  />
  <LessonList lessons={lessonItems} color="red" />
</BaseLayout>