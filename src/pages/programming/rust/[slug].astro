---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LessonSidebar from '../../../components/LessonSidebar.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import PrevNext from '../../../components/PrevNext.astro';
import SharedConceptBanner from '../../../components/SharedConceptBanner.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const lessons = await getCollection('programming', ({ id }) =>
    id.startsWith('rust/')
  );
  const sorted = lessons.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((entry, index) => ({
    params: { slug: entry.id.replace('rust/', '').replace(/\.md$/, '') },
    props: {
      entry,
      prev: sorted[index - 1] ?? null,
      next: sorted[index + 1] ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

const allLessons = await getCollection('programming', ({ id }) =>
  id.startsWith('rust/')
);
const sorted = allLessons.sort((a, b) => a.data.order - b.data.order);

const sidebarLessons = sorted.map(lesson => ({
  title: lesson.data.title,
  href: `/programming/rust/${lesson.id.replace('rust/', '').replace(/\.md$/, '')}`,
  order: lesson.data.order,
}));

const sharedConcepts = entry.data.sharedConcepts
  ? await getCollection('programming', ({ id }) =>
      entry.data.sharedConcepts!.some(sc => id === `_common/${sc}.md`)
    )
  : [];

const sharedConceptItems = sharedConcepts.map(sc => ({
  title: sc.data.title,
  href: `/programming/common/${sc.id.replace('_common/', '').replace(/\.md$/, '')}`,
}));

const prevLesson = prev
  ? { title: prev.data.title, href: `/programming/rust/${prev.id.replace('rust/', '').replace(/\.md$/, '')}` }
  : null;

const nextLesson = next
  ? { title: next.data.title, href: `/programming/rust/${next.id.replace('rust/', '').replace(/\.md$/, '')}` }
  : null;
---

<BaseLayout 
  title={entry.data.title}
  description={entry.data.description}
  keywords={entry.data.tags || ['Rust', 'programming']}
  ogType="article"
  certifications={entry.data.certifications}
>
  <div class="flex min-h-screen">

    <LessonSidebar
      lessons={sidebarLessons}
      currentSlug={Astro.params.slug}
      backHref="/programming/rust"
      backLabel="Rust"
      color="red"
    />

    <main class="flex-1 min-w-0 px-8 lg:px-16 py-12 max-w-3xl">

      <Breadcrumb crumbs={[
        { label: 'Programming', href: '/programming' },
        { label: 'Rust', href: '/programming/rust' },
        { label: entry.data.title },
      ]} />

      <div class="mb-10">
        <h1 class="text-4xl font-black tracking-tight font-mono mb-3">
          {entry.data.title}
        </h1>
        <p class="text-gray-400">{entry.data.description}</p>
        <div class="flex items-center gap-4 mt-4">
          {entry.data.duration && (
            <span class="text-xs text-gray-600">{entry.data.duration} min read</span>
          )}
          {entry.data.tags && entry.data.tags.map(tag => (
            <span class="text-xs px-2 py-0.5 rounded-full bg-red-500/10 text-red-400 border border-red-500/20">
              {tag}
            </span>
          ))}
        </div>
      </div>

      <SharedConceptBanner
        concepts={sharedConceptItems}
        relatedTrack="Rust"
      />

      <article class="prose prose-invert prose-red max-w-none">
        <Content />
      </article>

      <PrevNext prev={prevLesson} next={nextLesson} color="red" />

    </main>
  </div>
</BaseLayout>