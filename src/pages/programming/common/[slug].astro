---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LessonSidebar from '../../../components/LessonSidebar.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import PrevNext from '../../../components/PrevNext.astro';
import { Icon } from 'astro-icon/components';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('programming');
  const lessons = all.filter(({ id }) => id.startsWith('common/'));
  const sorted = lessons.sort((a, b) => a.data.order - b.data.order);

  console.log('getStaticPaths common ids:', lessons.map(l => l.id));

  return sorted.map((entry, index) => ({
    params: {
      slug: entry.id
        .replace('common/', '')
        .replace(/\.mdx$/, '')
        .replace(/\.md$/, ''),
    },
    props: {
      entry,
      prev: sorted[index - 1] ?? null,
      next: sorted[index + 1] ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

const all = await getCollection('programming');
const allCommon = all
  .filter(({ id }) => id.startsWith('common/'))
  .sort((a, b) => a.data.order - b.data.order);

const sidebarLessons = allCommon.map(lesson => ({
  title: lesson.data.title,
  href: `/programming/common/${lesson.id
    .replace('common/', '')
    .replace(/\.mdx$/, '')
    .replace(/\.md$/, '')}`,
  order: lesson.data.order,
  icon: lesson.data.icon,
}));

const prevLesson = prev ? {
  title: prev.data.title,
  href: `/programming/common/${prev.id.replace('common/', '').replace(/\.mdx$/, '').replace(/\.md$/, '')}`,
} : null;

const nextLesson = next ? {
  title: next.data.title,
  href: `/programming/common/${next.id.replace('common/', '').replace(/\.mdx$/, '').replace(/\.md$/, '')}`,
} : null;
---

<BaseLayout 
  title={entry.data.title}
  description={entry.data.description}
  keywords={entry.data.tags || ['programming', 'shared concepts']}
  ogType="article"
  certifications={entry.data.certifications}
>
  <LessonSidebar
      lessons={sidebarLessons}
      currentSlug={Astro.params.slug}
      backHref="/programming"
      backLabel="Programming"
      color="purple"
      groupLabel="Shared Concepts"
  >
    <main class="flex-1 min-w-0 px-8 lg:px-16 py-12 max-w-3xl">

      <Breadcrumb crumbs={[
        { label: 'Programming', href: '/programming' },
        { label: 'Shared Concepts', href: '/programming' },
        { label: entry.data.title },
      ]} />

      <!-- Shared badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-purple-500/10 border border-purple-500/20 mb-8">
        <span class="text-xs font-semibold text-purple-400 uppercase tracking-widest font-mono">
          🔗 Shared Concept
        </span>
      </div>

      <!-- Header -->
      <div class="mb-10">
        <div class="flex items-center gap-4 mb-3">
          {entry.data.icon && (
            <Icon name={entry.data.icon} class="w-10 h-10" />
          )}
          <h1 class="text-4xl font-black tracking-tight font-mono">
            {entry.data.title}
          </h1>
        </div>
        <p class="text-gray-400">{entry.data.description}</p>
        <div class="flex items-center gap-4 mt-4">
          {entry.data.duration && (
            <span class="text-xs text-gray-600">{entry.data.duration} min read</span>
          )}
          {entry.data.tags && entry.data.tags.map(tag => (
            <span class="text-xs px-2 py-0.5 rounded-full bg-purple-500/10 text-purple-400 border border-purple-500/20">
              {tag}
            </span>
          ))}
        </div>
      </div>

      <!-- Applies to -->
      {entry.data.sharedWith && entry.data.sharedWith.length > 0 && (
        <div class="mb-8 rounded-lg border border-white/10 bg-white/5 p-4">
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-3 font-mono">
            Applies to
          </p>
          <div class="flex gap-3">
            {entry.data.sharedWith.map(track => (
              <a
                href={`/programming/${track}`}
                class={`px-3 py-1 rounded-full text-xs font-semibold border transition-colors ${
                  track === 'java'
                    ? 'bg-orange-500/10 text-orange-400 border-orange-500/20 hover:bg-orange-500/20'
                    : 'bg-red-500/10 text-red-400 border-red-500/20 hover:bg-red-500/20'
                }`}
              >
                {track === 'java' ? '☕ Java' : '🦀 Rust'}
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Content -->
      <article class="prose prose-invert prose-purple max-w-none">
        <Content />
      </article>

      <PrevNext prev={prevLesson} next={nextLesson} color="purple" />

    </main>
  </LessonSidebar>
</BaseLayout>