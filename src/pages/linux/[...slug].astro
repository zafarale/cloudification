---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LessonSidebar from '../../components/LessonSidebar.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import PrevNext from '../../components/PrevNext.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const lessons = await getCollection('linux');
  const sorted = lessons.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((entry, i) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, '') },
    props: {
      entry,
      prev: i > 0
        ? { title: sorted[i - 1].data.title, href: `/linux/${sorted[i - 1].id.replace(/\.mdx?$/, '')}` }
        : null,
      next: i < sorted.length - 1
        ? { title: sorted[i + 1].data.title, href: `/linux/${sorted[i + 1].id.replace(/\.mdx?$/, '')}` }
        : null,
      sidebarLessons: sorted.map(l => ({
        title: l.data.title,
        href: `/linux/${l.id.replace(/\.mdx?$/, '')}`,
        order: l.data.order,
        icon: l.data.icon,
      })),
    },
  }));
}

interface Props {
  entry: CollectionEntry<'linux'>;
  prev: { title: string; href: string } | null;
  next: { title: string; href: string } | null;
  sidebarLessons: { title: string; href: string; order: number; icon?: string }[];
}

const { entry, prev, next, sidebarLessons } = Astro.props;
const { Content } = await render(entry);
const currentSlug = Astro.params.slug as string;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  keywords={entry.data.tags ?? ['linux', 'sysadmin']}
  ogType="article"
  certifications={entry.data.certifications}
>
  <LessonSidebar
    lessons={sidebarLessons}
    currentSlug={currentSlug}
    backHref="/linux"
    backLabel="Linux"
    color="yellow"
  >
    <main class="flex-1 min-w-0 px-8 lg:px-16 py-12 max-w-3xl">
      <Breadcrumb crumbs={[
        { label: 'Linux', href: '/linux' },
        { label: entry.data.title },
      ]} />

      <div class="mb-10">
        <h1 class="text-4xl font-black tracking-tight font-mono mb-3">{entry.data.title}</h1>
        <p class="text-gray-400">{entry.data.description}</p>
        <div class="flex items-center gap-4 mt-4">
          {entry.data.duration && (
            <span class="text-xs text-gray-600">{entry.data.duration} min read</span>
          )}
          {entry.data.tags && entry.data.tags.map((tag: string) => (
            <span class="text-xs px-2 py-0.5 rounded-full bg-yellow-500/10 text-yellow-400 border border-yellow-500/20">{tag}</span>
          ))}
        </div>
      </div>

      <article class="prose prose-invert prose-yellow max-w-none">
        <Content />
      </article>

      <PrevNext prev={prev} next={next} color="yellow" />
    </main>
  </LessonSidebar>
</BaseLayout>
