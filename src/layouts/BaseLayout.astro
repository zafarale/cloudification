---
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string[];
  ogImage?: string;
  ogType?: 'website' | 'article';
  canonical?: string;
  noindex?: boolean;
  author?: string;
  publishedTime?: string;
  modifiedTime?: string;
  certifications?: string[];
}

const {
  title,
  description = 'Structured learning paths for developers. Master programming, cloud, networking, data, and CI/CD with real content.',
  keywords = ['programming', 'cloud', 'networking', 'data', 'cicd', 'tutorials', 'learning'],
  ogImage = '/og-default.png',
  ogType = 'website',
  canonical,
  noindex = false,
  author = 'Acert',
  publishedTime,
  modifiedTime,
  certifications = [],
} = Astro.props;

const siteUrl = Astro.site?.toString() || 'https://acert.dev';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).toString();
const fullTitle = `${title} — Acert`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <title>{fullTitle}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- SEO Meta Tags -->
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(', ')} />
    <meta name="author" content={author} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Acert" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    
    <!-- Certifications (structured data for relevant certs) -->
    {certifications.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Course",
        "name": title,
        "description": description,
        "provider": {
          "@type": "Organization",
          "name": "Acert"
        },
        "hasCourseInstance": certifications.map(cert => ({
          "@type": "CourseInstance",
          "name": cert
        }))
      })} />
    )}
    <!-- Theme must be first in head to prevent flash -->
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const root = document.documentElement;
        let theme;
        if (stored) {
          theme = stored;
        } else {
          const hour = new Date().getHours();
          theme = hour >= 6 && hour < 18 ? "theme-day" : "theme-night";
        }
        root.classList.remove("theme-day", "theme-night");
        root.classList.add(theme);
        root.dataset.theme = theme === "theme-day" ? "light" : "dark";
      })();
    </script>
    

    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <nav
      class="px-8 py-4 flex items-center justify-between sticky top-0 backdrop-blur-md z-50"
      style="background-color: color-mix(in srgb, var(--bg) 85%, transparent); border-bottom: 1px solid var(--border);"
    >
      <a href="/" class="font-mono font-bold text-lg tracking-tight transition-colors"
        style="color: var(--text)">
        acert
      </a>
      <div class="flex items-center gap-6 text-sm" style="color: var(--text-muted)">
        <a href="/programming" class="hover:text-orange-400 transition-colors">Programming</a>
        <a href="/cloud" class="hover:text-blue-400 transition-colors">Cloud</a>
        <a href="/cicd" class="hover:text-green-400 transition-colors">CI/CD</a>
        <ThemeToggle />
      </div>
    </nav>

    <slot />

  </body>
</html>
