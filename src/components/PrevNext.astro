---
interface Lesson {
  title: string;
  href: string;
}

interface Props {
  prev: Lesson | null;
  next: Lesson | null;
  color?: string;
}

const { prev, next, color = 'white' } = Astro.props;
---

<div class="flex items-center justify-between mt-16 pt-8 border-t border-white/10">
  {prev ? (
    <a href={prev.href} class={`flex flex-col gap-1 group`}>
      <span class="text-xs text-gray-600 group-hover:text-gray-400 transition-colors">
        ← Previous
      </span>
      <span class={`text-sm font-medium group-hover:text-${color}-400 transition-colors`}>
        {prev.title}
      </span>
    </a>
  ) : <div />}

  {next ? (
    <a href={next.href} class="flex flex-col gap-1 items-end group">
      <span class="text-xs text-gray-600 group-hover:text-gray-400 transition-colors">
        Next →
      </span>
      <span class={`text-sm font-medium group-hover:text-${color}-400 transition-colors`}>
        {next.title}
      </span>
    </a>
  ) : <div />}
</div>