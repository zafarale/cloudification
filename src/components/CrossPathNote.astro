---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  emoji?: string;
  icon?: string;
  iconSize?: number;
}

const { title, description, emoji, icon = 'mdi:note-text-outline', iconSize = 20 } = Astro.props;
---

<section class="max-w-5xl mx-auto px-6 pb-24">
  <div class="rounded-xl p-5 flex items-start gap-4"
    style="border: 1px solid var(--border); background: var(--bg-card);">
    <span class="text-xl mt-0.5">
      {icon ? <Icon name={icon} size={iconSize} /> : emoji}
    </span>
    <div>
      <p class="font-semibold font-mono text-sm mb-1">
        {title}
      </p>
      <p class="text-sm leading-relaxed" style="color: var(--text-muted)">
        {description}
      </p>
    </div>
  </div>
</section>
