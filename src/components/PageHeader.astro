---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  icon?: string;
  iconName?: string;
  backHref: string;
  backLabel: string;
  lessonCount: number;
  totalDuration: number;
}

const { title, description, icon, iconName, backHref, backLabel, lessonCount, totalDuration } = Astro.props;
---

<section class="max-w-4xl mx-auto px-6 pt-16 pb-12">
  <a
    href={backHref}
    class="text-sm text-gray-500 hover:text-gray-300 transition-colors mb-6 inline-block"
  >
    ← {backLabel}
  </a>

  <div class="flex items-center gap-4 mb-4">
    {iconName && <Icon name={iconName} class="w-12 h-12" />}
    {icon && !iconName && <span class="text-5xl">{icon}</span>}
    <h1 class="text-5xl font-black tracking-tight font-mono">{title}</h1>
  </div>

  <p class="text-gray-400 text-lg max-w-2xl leading-relaxed">
    {description}
  </p>

  <div class="flex gap-6 mt-8 text-sm text-gray-500">
    <span>{lessonCount} lessons</span>
    {totalDuration > 0 && <span>{totalDuration} min total</span>}
  </div>
</section>