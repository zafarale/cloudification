---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!-- Trigger: full-width search bar -->
<button
  id="search-btn"
  aria-label="Search"
  data-base={base}
  class="w-full flex items-center gap-3 px-4 py-2 rounded-lg text-sm border transition-colors cursor-text text-left">
  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
  </svg>
  <span class="flex-1">Search lessons…</span>
  <kbd class="kbd kbd-xs hidden sm:inline-flex">⌘K</kbd>
</button>

<script is:inline>
  let initialized = false;

  async function openSearch() {
    const modal = document.getElementById('search-modal');
    if (!modal) return;
    modal.showModal();
    if (initialized) return;
    initialized = true;
    try {
      const base = document.getElementById('search-btn')?.dataset.base ?? '';
      const { PagefindUI } = await import(`${base}/pagefind/pagefind-ui.js`);
      new PagefindUI({
        element: '#pagefind-search',
        showSubResults: true,
        resetStyles: false,
        excerptLength: 20,
      });
      setTimeout(() => {
        const input = document.querySelector('#pagefind-search input');
        if (input) input.focus();
      }, 50);
    } catch {
      const el = document.getElementById('pagefind-search');
      if (el) el.innerHTML =
        '<p class="text-sm text-slate-500 p-4 text-center">Search index not available in development mode.</p>';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('search-btn')?.addEventListener('click', openSearch);
    // Close on backdrop click
    document.getElementById('search-modal')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) e.currentTarget.close();
    });
  });

  window.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
    if (e.key === 'Escape') {
      const modal = document.getElementById('search-modal');
      modal?.close();
    }
  });
</script>
