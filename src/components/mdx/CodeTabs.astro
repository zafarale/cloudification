---
import { Code } from 'astro-expressive-code/components';
import { Icon } from 'astro-icon/components';

interface Tab {
  label: string;
  code: string;
  lang?: string;
  icon?: string;
  emoji?: string;
}

interface Props {
  tabs: Tab[];
}

const { tabs } = Astro.props;

// Built-in Iconify icon defaults per label
// Uses logos: set — colourful brand icons
const ICON_DEFAULTS: Record<string, { icon: string; class?: string }> = {
  'macOS':      { icon: 'logos:apple',             class: 'text-white' },
  'Linux':      { icon: 'logos:linux-tux',          class: 'text-yellow-300' },
  'Windows':    { icon: 'logos:microsoft-windows',  class: '' },
  'Ubuntu':     { icon: 'devicon:ubuntu',           class: '' },
  'npm':        { icon: 'logos:npm',               class: '' },
  'yarn':       { icon: 'logos:yarn',              class: '' },
  'bun':        { icon: 'logos:bun',               class: '' },
  'pnpm':       { icon: 'logos:pnpm',              class: '' },
  'Docker':     { icon: 'logos:docker-icon',       class: '' },
  'AWS CLI':    { icon: 'logos:aws',               class: '' },
  'Azure CLI':  { icon: 'logos:microsoft-azure',   class: '' },
  'PowerShell': { icon: 'mdi:powershell',          class: 'text-blue-400' },
  'Bash':       { icon: 'devicon:bash',            class: '' },
  'Git':        { icon: 'logos:git-icon',          class: '' },
};

const id = Math.random().toString(36).slice(2, 8);
---

<div
  class="not-prose my-6 rounded-xl border border-white/10 overflow-hidden"
  data-tabs-wrapper={id}
>

  <!-- Tab bar -->
  <div class="flex border-b border-white/10 bg-white/[0.04] overflow-x-auto" role="tablist" aria-label="Code examples">
    {tabs.map((tab, index) => {
      const defaults = ICON_DEFAULTS[tab.label];
      const resolvedIcon = tab.icon ?? defaults?.icon ?? null;
      const resolvedEmoji = tab.emoji ?? null;

      return (
        <button
          id={`tab-${id}-${index}`}
          role="tab"
          aria-selected={index === 0 ? 'true' : 'false'}
          aria-controls={`panel-${id}-${index}`}
          tabindex={index === 0 ? 0 : -1}
          data-tab={index}
          data-tabs-id={id}
          class:list={[
            'flex items-center gap-2 px-4 py-2.5 text-sm font-medium font-mono',
            'whitespace-nowrap border-b-2 transition-all duration-200 cursor-pointer',
            'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-indigo-400',
            index === 0
              ? 'border-blue-400 text-blue-400'
              : 'border-transparent text-gray-500 hover:text-gray-300 hover:bg-white/5',
          ]}
        >
          {resolvedIcon ? (
            <Icon
              name={resolvedIcon}
              class:list={['w-4 h-4 shrink-0', defaults?.class ?? '']}
              aria-hidden="true"
            />
          ) : resolvedEmoji ? (
            <span class="text-sm leading-none" aria-hidden="true">{resolvedEmoji}</span>
          ) : null}
          {tab.label}
        </button>
      );
    })}
  </div>

  <!-- Panels -->
  {tabs.map((tab, index) => (
    <div
      id={`panel-${id}-${index}`}
      role="tabpanel"
      aria-labelledby={`tab-${id}-${index}`}
      tabindex={index === 0 ? 0 : -1}
      hidden={index !== 0}
      data-panel={index}
      data-tabs-id={id}
    >
      <Code
        code={tab.code.trim()}
        lang={tab.lang ?? 'bash'}
        frame="none"
      />
    </div>
  ))}

</div>

<script>
  document.querySelectorAll('[data-tabs-wrapper]').forEach((wrapper) => {
    const tabs = Array.from(wrapper.querySelectorAll('[role="tab"]'));
    const panels = Array.from(wrapper.querySelectorAll('[role="tabpanel"]'));

    function selectTab(index: number) {
      tabs.forEach((tab, i) => {
        const selected = i === index;
        tab.setAttribute('aria-selected', String(selected));
        (tab as HTMLElement).tabIndex = selected ? 0 : -1;
        tab.classList.toggle('text-blue-400', selected);
        tab.classList.toggle('border-blue-400', selected);
        tab.classList.toggle('text-gray-500', !selected);
        tab.classList.toggle('border-transparent', !selected);
      });
      panels.forEach((panel, i) => {
        if (i === index) {
          panel.removeAttribute('hidden');
        } else {
          panel.setAttribute('hidden', '');
        }
      });
    }

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => selectTab(i));
      tab.addEventListener('keydown', (e) => {
        const ke = e as KeyboardEvent;
        let next = -1;
        if (ke.key === 'ArrowRight')     next = (i + 1) % tabs.length;
        else if (ke.key === 'ArrowLeft') next = (i - 1 + tabs.length) % tabs.length;
        else if (ke.key === 'Home')      next = 0;
        else if (ke.key === 'End')       next = tabs.length - 1;
        if (next >= 0) {
          ke.preventDefault();
          selectTab(next);
          (tabs[next] as HTMLElement).focus();
        }
      });
    });
  });
</script>