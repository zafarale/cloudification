---
import { Code } from 'astro-expressive-code/components';
import { Icon } from 'astro-icon/components';

interface Tab {
  label: string;
  code: string;
  lang?: string;
  icon?: string;
  emoji?: string;
}

interface Props {
  tabs: Tab[];
}

const { tabs } = Astro.props;

// Built-in Iconify icon defaults per label
// Uses logos: set — colourful brand icons
const ICON_DEFAULTS: Record<string, { icon: string; class?: string }> = {
  'macOS':      { icon: 'logos:apple',             class: 'text-white' },
  'Linux':      { icon: 'logos:linux-tux',          class: 'text-yellow-300' },
  'Windows':    { icon: 'logos:microsoft-windows',  class: '' },
  'Ubuntu':     { icon: 'devicon:ubuntu',           class: '' },
  'npm':        { icon: 'logos:npm',               class: '' },
  'yarn':       { icon: 'logos:yarn',              class: '' },
  'bun':        { icon: 'logos:bun',               class: '' },
  'pnpm':       { icon: 'logos:pnpm',              class: '' },
  'Docker':     { icon: 'logos:docker-icon',       class: '' },
  'AWS CLI':    { icon: 'logos:aws',               class: '' },
  'Azure CLI':  { icon: 'logos:microsoft-azure',   class: '' },
  'PowerShell': { icon: 'mdi:powershell',          class: 'text-blue-400' },
  'Bash':       { icon: 'devicon:bash',            class: '' },
  'Git':        { icon: 'logos:git-icon',          class: '' },
};

const id = Math.random().toString(36).slice(2, 8);
---

<div
  class="not-prose my-6 rounded-xl border border-white/10 overflow-hidden"
  id={`tabs-${id}`}
>

  <!-- Tab bar -->
  <div class="flex border-b border-white/10 bg-white/[0.04] overflow-x-auto">
    {tabs.map((tab, index) => {
      const defaults = ICON_DEFAULTS[tab.label];
      const resolvedIcon = tab.icon ?? defaults?.icon ?? null;
      const resolvedEmoji = tab.emoji ?? null;

      return (
        <button
          data-tab={index}
          data-tabs-id={id}
          class:list={[
            'flex items-center gap-2 px-4 py-2.5 text-sm font-medium font-mono',
            'whitespace-nowrap border-b-2 transition-all duration-200 cursor-pointer',
            index === 0
              ? 'border-blue-400 text-blue-400'
              : 'border-transparent text-gray-500 hover:text-gray-300 hover:bg-white/5',
          ]}
        >
          {resolvedIcon ? (
            <Icon
              name={resolvedIcon}
              class:list={['w-4 h-4 shrink-0', defaults?.class ?? '']}
            />
          ) : resolvedEmoji ? (
            <span class="text-sm leading-none">{resolvedEmoji}</span>
          ) : null}
          {tab.label}
        </button>
      );
    })}
  </div>

  <!-- Panels -->
  {tabs.map((tab, index) => (
    <div
      data-panel={index}
      data-tabs-id={id}
      style={index !== 0 ? 'display:none' : ''}
    >
      <Code
        code={tab.code.trim()}
        lang={tab.lang ?? 'bash'}
        frame="none"
      />
    </div>
  ))}

</div>

<script>
  document.querySelectorAll('[data-tab]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.tabsId;
      const index = Number((btn as HTMLElement).dataset.tab);
      const wrapper = document.getElementById(`tabs-${id}`);
      if (!wrapper) return;

      wrapper.querySelectorAll('[data-tab]').forEach((b, i) => {
        b.classList.toggle('text-blue-400', i === index);
        b.classList.toggle('border-blue-400', i === index);
        b.classList.toggle('text-gray-500', i !== index);
        b.classList.toggle('border-transparent', i !== index);
      });

      wrapper.querySelectorAll('[data-panel]').forEach((panel, i) => {
        (panel as HTMLElement).style.display = i === index ? 'block' : 'none';
      });
    });
  });
</script>