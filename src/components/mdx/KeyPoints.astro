---
interface Props {
  title?: string;
}
const { title = 'Key Takeaways' } = Astro.props;
---

<div class="not-prose my-8 rounded-xl border border-purple-500/20 bg-purple-500/5 p-6">
  <p class="text-xs font-semibold uppercase tracking-widest text-purple-400 font-mono mb-4">
    ✦ {title}
  </p>
  <ul class="space-y-2">
    <slot />
  </ul>
</div>

<style>
  /* Style li elements injected via slot */
  div :global(li) {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.875rem;
    color: #cbd5e1;
    line-height: 1.6;
  }

  div :global(li)::before {
    content: '→';
    color: #a855f7;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    margin-top: 0.2rem;
    flex-shrink: 0;
  }

  div :global(ul) {
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>