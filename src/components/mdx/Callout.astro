---
import { Icon } from 'astro-icon/components';

interface Props {
  type?: 'info' | 'warning' | 'tip' | 'danger' | 'success';
  title?: string;
}
const { type = 'info', title } = Astro.props;

const styles = {
  info:    { border: 'border-blue-500/30',   bg: 'bg-blue-500/5',   text: 'text-blue-400',   icon: 'qlementine-icons:info-16' },
  warning: { border: 'border-yellow-500/30', bg: 'bg-yellow-500/5', text: 'text-yellow-400', icon: 'qlementine-icons:warning-16' },
  tip:     { border: 'border-green-500/30',  bg: 'bg-green-500/5',  text: 'text-green-400',  icon: 'qlementine-icons:light-bulb-on-16' },
  danger:  { border: 'border-red-500/30',    bg: 'bg-red-500/5',    text: 'text-red-400',    icon: 'qlementine-icons:warning-16' },
  success: { border: 'border-green-500/30',  bg: 'bg-green-500/5',  text: 'text-green-400',  icon: 'qlementine-icons:certified-16' },
};


const s = styles[type];
---

<div class={`rounded-lg border ${s.border} ${s.bg} p-4 my-6 not-prose`}>
  <p class={`text-xs font-semibold uppercase tracking-widest ${s.text} mb-2 font-mono flex items-center gap-2`}>
    <Icon name={s.icon} size={30} />
    {title ?? type}
  </p>
  <div class="text-sm text-gray-400 leading-relaxed">
    <slot />
  </div>
</div>