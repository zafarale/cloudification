---

<label class="flex cursor-pointer gap-2 items-center" aria-label="Toggle theme">

  <input id="theme-toggle" type="checkbox" class="toggle toggle-warning theme-controller" />

</label>

<script is:inline>
  const toggle = document.getElementById('theme-toggle');
  if (toggle) {
    // Checked = day (light), unchecked = night (dark)
    toggle.checked = document.documentElement.classList.contains('theme-day');

    toggle.addEventListener('change', () => {
      const next = toggle.checked ? 'theme-day' : 'theme-night';
      const root = document.documentElement;
      root.classList.remove('theme-day', 'theme-night');
      root.classList.add(next);
      localStorage.setItem('theme', next);
    });
  }
</script>