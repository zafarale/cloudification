---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
  iconDay?: string;
  iconNight?: string;
  emoji?: string;
  color: 'orange' | 'blue' | 'cyan' | 'green' | 'purple' | 'red' | 'yellow';
  tags?: { label?: string; icon?: string; iconDay?: string; iconNight?: string }[];
  ctaText?: string;
  lessonCount?: number;
}

const { 
  title, 
  description, 
  href, 
  icon, 
  iconDay,
  iconNight,
  emoji,
  color, 
  tags = [],
  ctaText = 'Start learning',
  lessonCount
} = Astro.props;

const colorMap = {
  orange: {
    border: 'hover:border-orange-500/50',
    shadow: 'hover:shadow-[0_0_40px_-8px_rgba(249,115,22,0.4)]',
    tag: 'bg-orange-500/15 text-orange-400 border-orange-500/25',
    text: 'group-hover:text-orange-400',
  },
  blue: {
    border: 'hover:border-blue-500/50',
    shadow: 'hover:shadow-[0_0_40px_-8px_rgba(59,130,246,0.4)]',
    tag: 'bg-blue-500/15 text-blue-400 border-blue-500/25',
    text: 'group-hover:text-blue-400',
  },
  cyan: {
    border: 'hover:border-cyan-500/50',
    shadow: 'hover:shadow-[0_0_40px_-8px_rgba(6,182,212,0.4)]',
    tag: 'bg-cyan-500/15 text-cyan-400 border-cyan-500/25',
    text: 'group-hover:text-cyan-400',
  },
  green: {
    border: 'hover:border-green-500/50',
    shadow: 'hover:shadow-[0_0_40px_-8px_rgba(34,197,94,0.4)]',
    tag: 'bg-green-500/15 text-green-400 border-green-500/25',
    text: 'group-hover:text-green-400',
  },
  purple: {
    border: 'hover:border-purple-500/50',
    shadow: 'hover:shadow-[0_0_40px_-8px_rgba(168,85,247,0.4)]',
    tag: 'bg-purple-500/15 text-purple-400 border-purple-500/25',
    text: 'group-hover:text-purple-400',
  },
  red: {
    border: 'hover:border-red-500/50',
    shadow: 'hover:shadow-[0_0_40px_-8px_rgba(239,68,68,0.4)]',
    tag: 'bg-red-500/15 text-red-400 border-red-500/25',
    text: 'group-hover:text-red-400',
  },
  yellow: {
    border: 'hover:border-yellow-500/50',
    shadow: 'hover:shadow-[0_0_40px_-8px_rgba(234,179,8,0.4)]',
    tag: 'bg-yellow-500/15 text-yellow-400 border-yellow-500/25',
    text: 'group-hover:text-yellow-400',
  },
};

const colors = colorMap[color];
---

<div class={`card w-full sm:w-80 border border-white/10 bg-white/5 transition-all duration-300 ${colors.border} ${colors.shadow} group`}>
  <div class="card-body gap-4">

    <!-- Icon -->
    <div class="text-3xl">
      {iconDay && iconNight ? (
        <>
          <Icon name={iconDay} class="w-10 h-10 theme-icon-day" />
          <Icon name={iconNight} class="w-10 h-10 theme-icon-night" />
        </>
      ) : icon ? (
        <Icon name={icon} class="w-10 h-10" />
      ) : (
        emoji
      )}
    </div>

    <!-- Title + description -->
    <div>
      <h2 class="card-title font-mono">{title}</h2>
      <p class="text-slate-400 text-sm leading-relaxed mt-1">{description}</p>
    </div>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 items-center">
        {tags.map(tag => (
          tag.icon || (tag.iconDay && tag.iconNight) ? (
            <div class="avatar">
              <div class={`mask mask-hexagon-2 w-8 h-8 ${colors.tag} flex items-center justify-center`}>
                {tag.iconDay && tag.iconNight ? (
                  <>
                    <Icon name={tag.iconDay} class="w-5 h-5 theme-icon-day" />
                    <Icon name={tag.iconNight} class="w-5 h-5 theme-icon-night" />
                  </>
                ) : (
                  <Icon name={tag.icon!} class="w-5 h-5" />
                )}
              </div>
            </div>
          ) : (
            <span class={`badge badge-sm border ${colors.tag}`}>{tag.label}</span>
          )
        ))}
      </div>
    )}

    <!-- Footer -->
    <div class="card-actions items-center justify-between mt-auto pt-1">
      {lessonCount !== undefined && (
        <span class="text-xs text-slate-500">{lessonCount} lessons</span>
      )}
      <a href={href} class={`btn btn-sm btn-ghost ml-auto ${colors.text}`}>
        {ctaText} →
      </a>
    </div>

  </div>
</div>
