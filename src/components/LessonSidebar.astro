---
import { Icon } from 'astro-icon/components';

interface Lesson {
  title: string;
  href: string;
  order: number;
  icon?: string;        // ← add this
}

interface Props {
  lessons: Lesson[];
  currentSlug: string;
  backHref: string;
  backLabel: string;
  color: string;
  groupLabel?: string;
}

const { lessons, currentSlug, backHref, backLabel, color, groupLabel } = Astro.props;
---

<aside class="hidden lg:flex flex-col w-64 shrink-0 border-r border-white/10 pt-8 pb-24 sticky top-0 h-screen overflow-y-auto">
  <div class="px-4 mb-6">
    <a href={backHref} class="text-xs text-gray-500 hover:text-gray-300 transition-colors">
      ← {backLabel}
    </a>
  </div>

  {groupLabel && (
    <div class="px-4 mb-4">
      <span class="text-xs font-semibold uppercase tracking-widest text-gray-600">
        {groupLabel}
      </span>
    </div>
  )}

  {lessons.map((lesson, index) => {
    const isActive = lesson.href === Astro.url.pathname;
    return (
      <a
        href={lesson.href}
        class={`flex items-center gap-3 px-4 py-2.5 text-sm transition-colors ${
          isActive
            ? `text-${color}-400 bg-${color}-500/10 border-r-2 border-${color}-500`
            : 'text-gray-500 hover:text-gray-300 hover:bg-white/5'
        }`}
      >
        <!-- Icon or number -->
        {lesson.icon ? (
          <div class="w-4 h-4 shrink-0 opacity-60">
            <Icon name={lesson.icon} class="w-4 h-4" />
          </div>
        ) : (
          <span class="tabular-nums text-xs w-5 shrink-0 opacity-50 font-mono">
            {String(index + 1).padStart(2, '0')}
          </span>
        )}
        {lesson.title}
      </a>
    );
  })}
</aside>